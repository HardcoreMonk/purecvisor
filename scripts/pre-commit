#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# PureCVisor pre-commit hook v1.0 — 커밋 전 품질 게이트
#
# [검증 단계] (조건부 최대 15단계)
#   1.  클러스터 빌드 (경고 0)                [C 변경 시]
#   2.  Single Edge 빌드 (경고 0)             [C 변경 시]
#   3.  유닛 테스트 (≥200 PASS)               [C 변경 시]
#   4.  REST↔RPC 정합성                       [REST/dispatcher 변경 시]
#   4b. ADR-0019 RBAC 정책 계약               [dispatcher/RBAC 변경 시]
#   5.  프론트엔드 패턴 (10건 초과 차단)      [UI 변경 시]
#   5b. i18n 키 정합성 (ko/en)                [UI 변경 시]
#   6.  cppcheck 정적 분석 (에러 차단)        [C 변경 + cppcheck 설치]
#   7.  바이너리 크기 (3MB 상한)              [C 변경 시]
#   8.  SAFE 통합 테스트                      [REST/UI 변경 + 데몬 실행]
#   8b. 보안 스캔 (OWASP Top 10)              [REST/UI 변경 + 데몬 실행]
#   9.  문서 정합성 (RPC/테스트 수)           [C 변경 시]
#   10. 신규 부채 마커 warn                   [C 변경 시]
#   11. ASan/UBSan test_runner (5분 타임아웃) [C 변경 + sanitize 가능]
#   12. Valgrind definite leak                [C 변경 + valgrind 설치]
#   13. gitleaks 시크릿 스캔                  [staged diff 대상]
#
# [설치]      make install-hooks
# [건너뛰기]  git commit --no-verify (지양)
#
# [설치]
#   make install-hooks
#
# [건너뛰기]
#   git commit --no-verify
# ══════════���════════════════════════════════════════════════════

set -uo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

FAILED=0
GATE=0
TOTAL_GATES=0

pass() { echo -e "${GREEN}PASS${NC} $1"; }
fail() { echo -e "${RED}FAIL${NC} $1"; FAILED=1; }
warn() { echo -e "${YELLOW}WARN${NC} $1"; }
skip() { echo -e "${YELLOW}SKIP${NC} $1"; }

# 변경된 파일 목록 (staged)
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

HAS_C_CHANGES=false
HAS_API_CHANGES=false
HAS_UI_CHANGES=false
HAS_RBAC_POLICY_CHANGES=false

echo "$STAGED" | grep -qE '\.(c|h)$' && HAS_C_CHANGES=true
echo "$STAGED" | grep -qE '(rest_server|dispatcher)\.(c|h)$' && HAS_API_CHANGES=true
echo "$STAGED" | grep -qE '^ui/' && HAS_UI_CHANGES=true
echo "$STAGED" | grep -qE '^(src/api/dispatcher\.c|src/modules/auth/pcv_rbac\.(c|h)|scripts/check_rbac_policies\.py)$' && HAS_RBAC_POLICY_CHANGES=true
HAS_CONTRACT_CHANGES=false
echo "$STAGED" | grep -qE '^(src/api/dispatcher\.c|src/api/rest_server\.c|src/api/grpc_server\.c|src/cli/purecvisorctl\.c|ui/.*\.js|scripts/check_rpc_consumers\.py|scripts/check_rpc_param_contract\.py|scripts/rpc_extract\.py|contracts/.*\.json)$' && HAS_CONTRACT_CHANGES=true
HAS_SYMBOL_CHANGES=false
echo "$STAGED" | grep -qE '\.(c|h)$|^scripts/(check_dead_exports\.py|dead_exports_baseline\.txt)$' && HAS_SYMBOL_CHANGES=true
HAS_COMMENT_COVERAGE_CHANGES=false
echo "$STAGED" | grep -qE '\.(c|h)$|^scripts/(check_comment_coverage\.py|comment_coverage_baseline\.txt)$' && HAS_COMMENT_COVERAGE_CHANGES=true
HAS_INGRESS_CHANGES=false
echo "$STAGED" | grep -qE '^(src/api/(ws|uds|grpc|rest)_server\.c|src/api/dispatcher\.c|src/modules/dispatcher/rpc_utils\.(c|h)|scripts/check_json_ingress\.py|scripts/json_ingress_baseline\.txt)$' && HAS_INGRESS_CHANGES=true
HAS_SAFETY_CHANGES=false
echo "$STAGED" | grep -qE '\.c$|^(scripts/check_safety_controls\.py|contracts/safety_controls(\.json|_baseline\.txt))$' && HAS_SAFETY_CHANGES=true
HAS_ERROR_CODE_CHANGES=false
echo "$STAGED" | grep -qE '\.(c|h)$|^(scripts/check_error_codes\.py|scripts/error_codes_baseline\.txt)$' && HAS_ERROR_CODE_CHANGES=true
HAS_CORS_CHANGES=false
echo "$STAGED" | grep -qE '^(src/api/rest_server\.c|scripts/check_cors_anchor\.py|scripts/tests/test_cors_anchor\.py)$' && HAS_CORS_CHANGES=true
HAS_SECRET_LOG_CHANGES=false
echo "$STAGED" | grep -qE '^(src/api/rest_server\.c|scripts/check_secret_logging\.py|scripts/tests/test_secret_logging\.py)$' && HAS_SECRET_LOG_CHANGES=true
HAS_SSRF_CHANGES=false
echo "$STAGED" | grep -qE '\.c$|^(scripts/check_ssrf_guard\.py|scripts/tests/test_ssrf_guard\.py)$' && HAS_SSRF_CHANGES=true
HAS_GRPC_AUTHZ_CHANGES=false
echo "$STAGED" | grep -qE '^(src/api/grpc_server\.c|scripts/check_grpc_authz\.py|scripts/tests/test_grpc_authz\.py)$' && HAS_GRPC_AUTHZ_CHANGES=true
HAS_SSRF_TARGET_CHANGES=false
echo "$STAGED" | grep -qE '\.c$|^(scripts/check_ssrf_target_guard\.py|scripts/tests/test_ssrf_target_guard\.py)$' && HAS_SSRF_TARGET_CHANGES=true
HAS_AUDIT_HASHCHAIN_CHANGES=false
echo "$STAGED" | grep -qE '^(src/modules/audit/pcv_audit\.(c|h)|scripts/check_audit_hashchain\.py|scripts/tests/test_audit_hashchain\.py)$' && HAS_AUDIT_HASHCHAIN_CHANGES=true
HAS_RNG_SAFE_CHANGES=false
echo "$STAGED" | grep -qE '^(src/modules/auth/pcv_rbac\.c|src/utils/pcv_jwt\.c|scripts/check_rng_safe\.py|scripts/tests/test_rng_safe\.py)$' && HAS_RNG_SAFE_CHANGES=true
HAS_UDS_AUTHZ_CHANGES=false
echo "$STAGED" | grep -qE '^(src/api/uds_server\.c|src/utils/pcv_config\.c|scripts/check_uds_authz\.py|scripts/tests/test_uds_authz\.py)$' && HAS_UDS_AUTHZ_CHANGES=true
HAS_TRANSPORT_BIND_CHANGES=false
echo "$STAGED" | grep -qE '^(src/api/rest_server\.c|scripts/check_transport_bind\.py|scripts/tests/test_transport_bind\.py)$' && HAS_TRANSPORT_BIND_CHANGES=true
HAS_CONTAINER_OWNER_SCOPE_CHANGES=false
echo "$STAGED" | grep -qE '^(src/api/dispatcher\.c|src/modules/dispatcher/handler_container\.c|src/modules/lxc/lxc_owner\.(c|h)|scripts/check_container_owner_scope\.py|scripts/tests/test_container_owner_scope\.py)$' && HAS_CONTAINER_OWNER_SCOPE_CHANGES=true
HAS_MTLS_WIRING_CHANGES=false
echo "$STAGED" | grep -qE '^(src/api/rest_server\.c|src/utils/pcv_tls\.(c|h)|scripts/check_mtls_wiring\.py|scripts/tests/test_mtls_wiring\.py)$' && HAS_MTLS_WIRING_CHANGES=true
HAS_TLS_MIN_VERSION_CHANGES=false
echo "$STAGED" | grep -qE '^(src/utils/pcv_tls\.(c|h)|scripts/check_tls_min_version\.py|scripts/tests/test_tls_min_version\.py)$' && HAS_TLS_MIN_VERSION_CHANGES=true

# ── 1. 클러스터 빌드 검증 ────────────────────────────────────
if $HAS_C_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] 클러스터 빌드 검증 (경고 0)${NC}"
    BUILD_OUT=$(make all 2>&1)
    WARNINGS=$(echo "$BUILD_OUT" | grep -c "warning:" || true)
    if [ "$WARNINGS" -gt 0 ]; then
        fail "빌드 경고 ${WARNINGS}건 발견"
        echo "$BUILD_OUT" | grep "warning:" | head -5
    else
        pass "빌드 경고 0건"
    fi
else
    skip "[1] C 소스 변경 없음 — 빌드 검증 생략"
fi

# ── 2. Single Edge 빌드 검증 ──��──────────────────────────────
if $HAS_C_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] Single Edge 빌드 검증${NC}"
    SINGLE_OUT=$(make clean >/dev/null 2>&1 && make single 2>&1)
    # Week 4: 화이트리스트 부채 제거 — 실측 0 경고 확인 후 strict 전환
    SINGLE_WARNS=$(echo "$SINGLE_OUT" | grep -c "warning:" || true)
    if [ "$SINGLE_WARNS" -gt 0 ]; then
        fail "Single Edge 빌드 신규 경고 ${SINGLE_WARNS}건"
    else
        pass "Single Edge 빌드 경고 0건"
    fi
    # Single Edge 빌드 상태 유지
    make clean >/dev/null 2>&1 && make single >/dev/null 2>&1
fi

# ── 3. 유닛 테스트 ──────────────────────────────────────���────
if $HAS_C_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] 유닛 테스트${NC}"

    make test 2>&1 > /tmp/pcv_test_output.txt
    REAL_FAILS=$(grep "^not ok" /tmp/pcv_test_output.txt | wc -l || true)
    PASS_COUNT=$(grep -c "^ok" /tmp/pcv_test_output.txt || true)

    if [ "$REAL_FAILS" -gt 0 ]; then
        fail "${REAL_FAILS}건 테스트 실패"
        grep "^not ok" /tmp/pcv_test_output.txt
    elif [ "$PASS_COUNT" -lt 200 ]; then
        fail "테스트 ${PASS_COUNT}건만 통과 (최소 200건 필요 — 테스트 등록 누락?)"
    else
        pass "${PASS_COUNT}건 ��스트 통과"
    fi
    rm -f /tmp/pcv_test_output.txt
else
    skip "[3] C 소스 변경 없음 — 테스트 생략"
fi

# ── 4. REST ↔ RPC 정합성 ────────────────────────────────────
if $HAS_API_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] REST ↔ RPC 정합성 검증${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    if [ -x "$SCRIPT_DIR/verify_api_consistency.sh" ]; then
        RESULT=$("$SCRIPT_DIR/verify_api_consistency.sh" --ci 2>&1)
        API_EXIT=$?
        if [ $API_EXIT -ne 0 ]; then
            fail "REST→RPC 불일치 발견"
            echo "$RESULT" | grep "FAIL"
        else
            FAIL_LINE=$(echo "$RESULT" | grep "FAIL:" | head -1)
            pass "REST↔RPC ��합성 통과 ($FAIL_LINE)"
        fi
    else
        skip "verify_api_consistency.sh 없음"
    fi
else
    skip "[4] REST/Dispatcher 변경 없음 — 정합성 검증 생략"
fi

# ── 4b. ADR-0019 RBAC 정책 계약 ─────────────────────────────
if $HAS_RBAC_POLICY_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] ADR-0019 RBAC 정책 계약${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    RBAC_OUT=$(python3 "$SCRIPT_DIR/check_rbac_policies.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "RBAC 정책 매핑 또는 owner-scope 계약 회귀"
        echo "$RBAC_OUT" | tail -20
    else
        pass "$(echo "$RBAC_OUT" | tail -1)"
    fi
else
    skip "[$((GATE+1))] RBAC 정책 변경 없음 — ADR-0019 계약 검증 생략"
fi

# ── 4c. AF-C4 RPC 소비⊆등록 계약 (check-rpc-consumers) ─────────────────
if $HAS_CONTRACT_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] AF-C4 RPC 소비⊆등록 계약${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    RPC_OUT=$(python3 "$SCRIPT_DIR/check_rpc_consumers.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "미등록 RPC 메서드 소비 (CLI/FE 계약 파손 → -32601)"
        echo "$RPC_OUT" | tail -20
    else
        pass "$(echo "$RPC_OUT" | tail -1)"
    fi
else
    skip "[$((GATE+1))] 계약 소비/등록 변경 없음 — AF-C4 검증 생략"
fi

# ── 4d. dead export 게이트 (check-dead-exports) ─────────────────────────
if $HAS_SYMBOL_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] dead export${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    DE_OUT=$(python3 "$SCRIPT_DIR/check_dead_exports.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "신규 dead export (헤더 선언 함수 사용처0 — 배선/삭제/waiver 필요)"
        echo "$DE_OUT" | tail -15
    else
        pass "$(echo "$DE_OUT" | grep -E '^\[' | tail -1)"
    fi
else
    skip "[$((GATE+1))] .c/.h 및 게이트 스크립트 변경 없음 — dead export 검증 생략"
fi

# ── 4d-2. 주석 커버리지 게이트 (check-comment-coverage) ──────────────────
if $HAS_COMMENT_COVERAGE_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] 주석 커버리지${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    CC_OUT=$(python3 "$SCRIPT_DIR/check_comment_coverage.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "주석 커버리지 위반 (파일 헤더 부재/저밀도 — 헤더 추가 또는 waiver)"
        echo "$CC_OUT" | tail -15
    else
        pass "$(echo "$CC_OUT" | grep -E '^\[' | tail -1)"
    fi
else
    skip "[$((GATE+1))] .c/.h 및 게이트 스크립트 변경 없음 — 주석 커버리지 검증 생략"
fi

# ── 4e. RPC param-key 계약 (Stage 2, check-rpc-param-contract) ──────────
if $HAS_CONTRACT_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] RPC param-key 계약 (Stage 2)${NC}"
    PC_OUT=$(python3 "$SCRIPT_DIR/check_rpc_param_contract.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "param-key 계약 위반 (신규 -32602 파손)"
        echo "$PC_OUT" | tail -20
    else
        pass "$(echo "$PC_OUT" | grep -E '^\[' | tail -1)"
    fi
else
    skip "[$((GATE+1))] 계약 소비/등록 변경 없음 — param-key 계약 검증 생략"
fi

# ── 4f. JSON 파싱 초크포인트 (check-json-ingress) ───────────────────────
if $HAS_INGRESS_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] JSON 파싱 초크포인트${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    JI_OUT=$(python3 "$SCRIPT_DIR/check_json_ingress.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "무가드 경계 JSON 파싱 (래퍼/waiver 누락)"
        echo "$JI_OUT" | tail -10
    else
        pass "$(echo "$JI_OUT" | grep -E '^\[' | tail -1)"
    fi
else
    skip "[$((GATE+1))] 데몬 경계 파일 변경 없음 — JSON 파싱 초크포인트 검증 생략"
fi

# ── 4g. 안전통제 효과 테스트 레지스트리 (check-safety-controls) ─────────
if $HAS_SAFETY_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] 안전통제 효과 테스트${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    SC_OUT=$(python3 "$SCRIPT_DIR/check_safety_controls.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "안전통제 계약 위반 (미등록 마커/신규 미검증 통제)"
        echo "$SC_OUT" | tail -15
    else
        pass "$(echo "$SC_OUT" | grep -E '^\[' | tail -1)"
    fi
else
    skip "[$((GATE+1))] C 소스/안전통제 레지스트리 변경 없음 — 안전통제 게이트 생략"
fi

# ── 4h. raw 에러코드 리터럴 방지 게이트 (check-error-codes, DISP-6) ─────
if $HAS_ERROR_CODE_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] raw 에러코드 리터럴 방지${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    EC_OUT=$(python3 "$SCRIPT_DIR/check_error_codes.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "raw 에러코드 리터럴 또는 PCV_ERR_ 재도입 발견"
        echo "$EC_OUT" | tail -15
    else
        pass "$(echo "$EC_OUT" | grep -E '^\[' | tail -1)"
    fi
else
    skip "[$((GATE+1))] .c/.h 및 게이트 스크립트/baseline 변경 없음 — 에러코드 게이트 생략"
fi

# ── 4i. audit 배치 계약 게이트 (check-audit-placement, ADR-0018) ───
if $HAS_C_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] audit 배치 계약 (async registry/audit/WS completion)${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    AP_OUT=$(python3 "$SCRIPT_DIR/check_audit_placement.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "audit 배치 계약 위반 (ADR-0018 — async 등록/audit/WS completion)"
        echo "$AP_OUT" | tail -15
    else
        pass "$(echo "$AP_OUT" | grep -E '^\[|PASS' | tail -1)"
    fi
else
    skip "[$((GATE+1))] .c/.h 변경 없음 — audit 배치 게이트 생략"
fi

# ── 4j. CORS 오리진 앵커 게이트 (check-cors-anchor, Wave A A05·V3·V13) ──
if $HAS_CORS_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] CORS 오리진 앵커 검증${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    CORS_OUT=$(python3 "$SCRIPT_DIR/check_cors_anchor.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "CORS origin substring 우회 재등장 또는 _cors_origin_allowed 미사용"
        echo "$CORS_OUT" | tail -15
    else
        pass "$(echo "$CORS_OUT" | grep -E '^\[' | tail -1)"
    fi
else
    skip "[$((GATE+1))] rest_server.c/CORS 게이트 변경 없음 — CORS 앵커 게이트 생략"
fi

# ── 4k. 감사 로그 자격증명 마스킹 게이트 (check-secret-logging, A09·V14·V16) ──
if $HAS_SECRET_LOG_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] 감사 로그 자격증명 마스킹${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    SL_OUT=$(python3 "$SCRIPT_DIR/check_secret_logging.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "is_auth 산정에서 _body_has_secret 미사용 (평문 자격증명 저널 기록)"
        echo "$SL_OUT" | tail -15
    else
        pass "$(echo "$SL_OUT" | grep -E '^\[' | tail -1)"
    fi
else
    skip "[$((GATE+1))] rest_server.c/마스킹 게이트 변경 없음 — 자격증명 마스킹 게이트 생략"
fi

# ── 4l. 아웃바운드 리다이렉트 금지 게이트 (check-ssrf-guard, A10·V4) ──
if $HAS_SSRF_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] 아웃바운드 리다이렉트 금지${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    SSRF_OUT=$(python3 "$SCRIPT_DIR/check_ssrf_guard.py" 2>&1)
    if [ $? -ne 0 ]; then
        fail "아웃바운드 soup_message_new에 SOUP_MESSAGE_NO_REDIRECT 누락 (SSRF)"
        echo "$SSRF_OUT" | tail -15
    else
        pass "$(echo "$SSRF_OUT" | grep -E '^\[' | tail -1)"
    fi
else
    skip "[$((GATE+1))] .c/SSRF 게이트 변경 없음 — 아웃바운드 리다이렉트 게이트 생략"
fi

# ── 4m. gRPC 인증/RBAC 게이트 (check-grpc-authz, Wave B / A01·V8) ──
if $HAS_GRPC_AUTHZ_CHANGES; then
    GATE=$((GATE+1))
