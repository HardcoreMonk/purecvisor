fi

# ── 5. 프론트엔드 검증 (강화: 10건 초과 차단) ────────────────
if $HAS_UI_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] 프���트엔드 패턴 검증${NC}"
    UI_DIR="$(git rev-parse --show-toplevel)/ui/modules"
    ISSUES=0

    for f in "$UI_DIR"/*.js; do
        bn=$(basename "$f")
        case "$bn" in api.js|endpoints.js|theme.js|help.js|nav.js|ui.js|i18n.js|sw.js) continue ;; esac
        COUNT=$(grep -c "API_BASE + '" "$f" 2>/dev/null || true)
        if [ "$COUNT" -gt 0 ]; then
            warn "$bn: ${COUNT}건 하드코딩된 API_BASE (EP 레지스트리 사용 권장)"
            ISSUES=$((ISSUES + COUNT))
        fi
    done

    LEGACY=$(grep -rl "\.data || " "$UI_DIR"/*.js 2>/dev/null | grep -v api.js | wc -l || true)
    if [ "$LEGACY" -gt 0 ]; then
        warn "${LEGACY}개 파일에서 레거시 .data || 패턴 발견 (unwrapData/unwrapList 사용 권장)"
        ISSUES=$((ISSUES + LEGACY))
    fi

    if [ "$ISSUES" -gt 10 ]; then
        fail "프론트엔드 하드코딩 ${ISSUES}건 > 10건 임계값 초과"
    elif [ "$ISSUES" -gt 0 ]; then
        warn "프론트엔드 하드코딩 ${ISSUES}건 (10건 이하 — 허용)"
    else
        pass "프론트엔드 패턴 검증 통과"
    fi

    # ESLint (errors only, 프론트 #4-B) — 설치 시에만 실행.
    # node_modules 존재 여부가 아니라 `npx --no-install eslint` 자체 가용성으로
    # 판별 (Makefile ui-bundle의 esbuild 감지와 동일 관례) — puppeteer 등
    # 다른 devDependency만 설치되고 eslint 미설치인 환경에서도 정확히 skip.
    if command -v node &>/dev/null && [ -f package.json ]; then
        GATE=$((GATE+1))
        echo -e "${CYAN}[$GATE] ESLint (zero errors)${NC}"
        if npx --no-install eslint --version >/dev/null 2>&1; then
            ES_OUT=$(npx --no-install eslint ui/app.js ui/i18n.js ui/sw.js ui/modules 2>&1)
            ES_EXIT=$?
            if [ $ES_EXIT -ne 0 ]; then
                fail "ESLint 에러 — npx eslint 출력 확인"
                echo "$ES_OUT" | tail -10
            else
                pass "$(echo "$ES_OUT" | grep -oE '[0-9]+ problems.*' | head -1 || echo 'ESLint 통과 (0 errors)')"
            fi
        else
            skip "ESLint 미설치 — npm install 필요"
        fi
    fi

    # OpenAPI 동기화 (REST_ENDPOINTS.md ↔ openapi.yaml)
    if echo "$STAGED" | grep -qE "(REST_ENDPOINTS\.md|openapi\.yaml|gen_openapi\.py)"; then
        GATE=$((GATE+1))
        echo -e "${CYAN}[$GATE] OpenAPI 동기화${NC}"
        if python3 scripts/gen_openapi.py --check 2>/tmp/oapi.log; then
            pass "OpenAPI 동기화 OK"
        else
            fail "openapi.yaml가 REST_ENDPOINTS.md와 불일치"
            cat /tmp/oapi.log
        fi
    fi

    # UI 번들 최신성 (modules/*.js ↔ app.bundle.js ↔ sw.js CACHE_NAME)
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] UI 번들 최신성${NC}"
    if [ -x scripts/check_ui_bundle_fresh.py ]; then
        BUNDLE_OUT=$(python3 scripts/check_ui_bundle_fresh.py 2>&1)
        if [ $? -ne 0 ]; then
            fail "ui/app.bundle.js 또는 ui/sw.js가 ui/modules/*.js와 불일치"
            echo "$BUNDLE_OUT" | tail -10
        else
            pass "$(echo "$BUNDLE_OUT" | head -1)"
        fi
    fi

    # XSS 스캐너 (프로젝트별 esc/H/_L/t 헬퍼 인식)
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] XSS 패턴 검증${NC}"
    if [ -x scripts/check_xss.py ]; then
        XSS_OUT=$(python3 scripts/check_xss.py 2>&1)
        if [ $? -ne 0 ]; then
            fail "innerHTML에 sanitizer 미적용 식별자 발견"
            echo "$XSS_OUT" | tail -15
        else
            pass "$(echo "$XSS_OUT" | head -1)"
        fi
    fi

    # i18n 키 정합성 (ko/en)
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] i18n 키 정합성 (ko/en)${NC}"
    SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
    if [ -x "$SCRIPT_DIR/check_i18n.sh" ]; then
        I18N_OUT=$("$SCRIPT_DIR/check_i18n.sh" ui/i18n.js 2>&1)
        if [ $? -ne 0 ]; then
            fail "i18n 키 누락"
            echo "$I18N_OUT" | tail -20
        else
            pass "$(echo "$I18N_OUT" | head -1)"
        fi
    fi
else
    skip "[$((GATE+1))] UI 변경 없음 — 프론트엔드/i18n 검증 생략"
fi

# ── 6. cppcheck 정적 분석 (C 소스 변경 시) ───────────────────
if $HAS_C_CHANGES && command -v cppcheck &>/dev/null; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] cppcheck 정적 분석${NC}"
    CPP_OUT=$(cppcheck --enable=warning,performance \
        --suppress=missingIncludeSystem --suppress=unknownMacro \
        --inline-suppr --error-exitcode=1 \
        -I include -I src -I include/purecvisor \
        $(pkg-config --cflags-only-I glib-2.0 json-glib-1.0 libvirt 2>/dev/null) \
        src/ 2>&1)
    CPP_EXIT=$?
    REAL_ERRS=$(echo "$CPP_OUT" | grep '(error)' | grep -v "protoc-c\|preprocessorErrorDirective" | wc -l || true)
    if [ "$REAL_ERRS" -gt 0 ]; then
        fail "cppcheck 에러 ${REAL_ERRS}건"
        echo "$CPP_OUT" | grep '(error)' | grep -v "protoc-c\|preprocessorErrorDirective" | head -5
    else
        pass "cppcheck 에러 0건"
    fi
fi

# ── 7. 바이너리 크기 검증 ────────────────────────────────────
if $HAS_C_CHANGES && [ -f bin/purecvisorsd ]; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] 바이너리 크기 검증 (3MB 상한)${NC}"
    SIZE=$(stat -c%s bin/purecvisorsd 2>/dev/null || echo 0)
    SIZE_KB=$((SIZE / 1024))
    if [ "$SIZE" -gt 3145728 ]; then
        fail "바이너리 ${SIZE_KB}KB > 3MB 상한"
    else
        pass "바이너리 ${SIZE_KB}KB (3MB 이내)"
    fi
fi

# ── 8. SAFE 통합 테스트 (데몬 실행 중) ───────────────────────
if $HAS_API_CHANGES || $HAS_UI_CHANGES; then
    if curl -s -o /dev/null -w "%{http_code}" "http://localhost/api/v1/health" 2>/dev/null | grep -q "200"; then
        GATE=$((GATE+1))
        echo -e "${CYAN}[$GATE] SAFE 통합 테스트 (데몬 감지됨)${NC}"
        SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
        if [ -x "$SCRIPT_DIR/run_auto_tests.sh" ]; then
            INTEG_OUT=$("$SCRIPT_DIR/run_auto_tests.sh" --tier 1 --ci 2>&1)
            INTEG_EXIT=$?
            INTEG_PASS=$(echo "$INTEG_OUT" | grep "PASS:" | tail -1 | sed 's/.*PASS: \([0-9]*\).*/\1/' || echo 0)
            INTEG_FAIL=$(echo "$INTEG_OUT" | grep "FAIL:" | tail -1 | sed 's/.*FAIL: \([0-9]*\).*/\1/' || echo 0)
            if [ "$INTEG_EXIT" -ne 0 ] && [ "${INTEG_FAIL:-0}" -gt 0 ]; then
                fail "SAFE 통합 테스트 ${INTEG_FAIL}건 실패"
            else
                pass "SAFE 통합 테스�� 통과 (${INTEG_PASS}건)"
            fi
        fi

        # 보안 스캔 (OWASP Top 10) — 데몬 실행 중일 때만
        GATE=$((GATE+1))
        echo -e "${CYAN}[$GATE] 보안 스캔 (OWASP Top 10)${NC}"
        SEC_SCRIPT="$(git rev-parse --show-toplevel)/tests/integration/test_security_scan.sh"
        if [ -x "$SEC_SCRIPT" ]; then
            SEC_OUT=$(timeout 120 bash "$SEC_SCRIPT" localhost 2>&1)
            SEC_EXIT=$?
            SEC_FAIL=$(echo "$SEC_OUT" | grep -oP 'FAIL: \K[0-9]+' | tail -1 || echo 0)
            if [ "$SEC_EXIT" -eq 124 ]; then
                warn "보안 스캔 타임아웃 (120s)"
            elif [ "$SEC_EXIT" -ne 0 ]; then
                fail "보안 스캔 ${SEC_FAIL}건 실패"
                echo "$SEC_OUT" | grep "\[FAIL\]" | head -10
            else
                SEC_PASS=$(echo "$SEC_OUT" | grep -oP 'PASS: \K[0-9]+' | tail -1 || echo 0)
                pass "보안 스캔 통과 (${SEC_PASS}건)"
            fi
        else
            skip "test_security_scan.sh 없음"
        fi
    else
        skip "[$((GATE+1))] 데몬 미실행 — SAFE 통합/보안 스캔 생략"
    fi
else
    skip "[$((GATE+1))] REST/UI 변경 없음 — 통합/보안 검사 생략"
fi

# ── 9. 문서 정합성 검사 (C 소스 변경 시) ─────────────────────
if $HAS_C_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] 문서 정합성 검사${NC}"
    DOC_ISSUES=0
    PROJECT_ROOT="$(git rev-parse --show-toplevel)"

    # RPC 수 검증: dispatcher.c 등록 수 vs CLAUDE.md 기재 수
    ACTUAL_RPC=$(grep -c "g_hash_table_insert.*g_rpc_routes" "$PROJECT_ROOT/src/api/dispatcher.c" || true)
    DOC_RPC=$(grep -oP "RPC.*?(\d+)개" "$PROJECT_ROOT/CLAUDE.md" 2>/dev/null | head -1 | grep -oP "\d+" || echo 0)
    if [ "$ACTUAL_RPC" -gt 0 ] && [ "$DOC_RPC" -gt 0 ] && [ "$ACTUAL_RPC" != "$DOC_RPC" ]; then
        warn "RPC 수 불일치: dispatcher=$ACTUAL_RPC, CLAUDE.md=$DOC_RPC"
        DOC_ISSUES=$((DOC_ISSUES + 1))
    fi

    # 테스트 수 검증: 실제 PASS 수 vs CLAUDE.md 기재 수
    if [ -f "$PROJECT_ROOT/test_results.txt" ]; then
        ACTUAL_TESTS=$(grep -c "^ok" "$PROJECT_ROOT/test_results.txt" 2>/dev/null || true)
        DOC_TESTS=$(grep -oP "테스트.*?(\d+)" "$PROJECT_ROOT/CLAUDE.md" 2>/dev/null | head -1 | grep -oP "\d+" | head -1 || echo 0)
        if [ "$ACTUAL_TESTS" -gt 0 ] && [ "$DOC_TESTS" -gt 0 ] && [ "$ACTUAL_TESTS" != "$DOC_TESTS" ]; then
            warn "테스트 수 불일치: 실제=$ACTUAL_TESTS, CLAUDE.md=$DOC_TESTS"
            DOC_ISSUES=$((DOC_ISSUES + 1))
        fi
    fi

    if [ "$DOC_ISSUES" -eq 0 ]; then
        pass "문서 정합성 통과"
    fi
fi

# ── 10. 신규 부채 마커 차단 ────────────────────────────────
if $HAS_C_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] 신규 부채 마커 검사${NC}"
    DEBT_MARK_1='TO''DO'
    DEBT_MARK_2='FIX''ME'
    DEBT_MARK_PATTERN="${DEBT_MARK_1}|${DEBT_MARK_2}"
    # staged diff에서 신규 추가된 부채 마커만 검사 (+줄)
    NEW_DEBT_MARKS=$(git diff --cached --diff-filter=ACMR -U0 -- '*.c' '*.h' | grep "^+" | grep -v "^+++" | grep -iE "$DEBT_MARK_PATTERN" | wc -l || true)
    if [ "$NEW_DEBT_MARKS" -gt 0 ]; then
        warn "신규 부채 마커 ${NEW_DEBT_MARKS}건 (의도적이면 무시)"
        git diff --cached --diff-filter=ACMR -U0 -- '*.c' '*.h' | grep "^+" | grep -v "^+++" | grep -iE "$DEBT_MARK_PATTERN" | head -5
    else
        pass "신규 부채 마커 0건"
    fi
fi

# ── 11. 커밋 메시지 포맷 검사 (commit-msg 대용) ──────────────
# Note: 실제 커밋 메시지는 commit-msg hook에서 검사해야 하지만,
# pre-commit에서는 staged 파일 기반 검사만 수행.

# ── 12. Valgrind 빠른 검사 (test_runner 대상, C 변경 시) ─────
if $HAS_C_CHANGES && command -v valgrind &>/dev/null && [ -f test_runner ]; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] Valgrind 빠른 검사${NC}"
    VG_OUT=$(G_SLICE=always-malloc G_DEBUG=gc-friendly timeout 60 valgrind \
        --leak-check=full --show-leak-kinds=definite \
        --errors-for-leak-kinds=definite --error-exitcode=42 \
        --suppressions=/usr/share/glib-2.0/valgrind/glib.supp \
        ./test_runner 2>&1)
    VG_EXIT=$?
    if [ "$VG_EXIT" -eq 42 ]; then
        DEFINITE=$(echo "$VG_OUT" | grep "definitely lost:" | grep -v " 0 bytes" | head -1)
        fail "Valgrind definite leak: $DEFINITE"
    elif [ "$VG_EXIT" -eq 124 ]; then
        warn "Valgrind 타임아웃 (60초) — 건너뜀"
    else
        pass "Valgrind definite leak 0건"
    fi
fi

# ── 11. ASan/UBSan test_runner (Valgrind 보완, 빠름) ─────────
if $HAS_C_CHANGES; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] ASan/UBSan test_runner${NC}"
    SAN_OUT=$(timeout 300 make sanitize 2>&1)
    SAN_EXIT=$?
    if [ "$SAN_EXIT" -eq 124 ]; then
        warn "ASan 5분 타임아웃 — 건너뜀"
    elif echo "$SAN_OUT" | grep -qE "(ERROR: AddressSanitizer|runtime error:|SUMMARY: UndefinedBehaviorSanitizer)"; then
        fail "ASan/UBSan 오류 발견"
        echo "$SAN_OUT" | grep -E "(ERROR|runtime error|SUMMARY)" | head -10
    else
        pass "ASan/UBSan 통과"
    fi
    # 빌드 잔여물 정리 + Single Edge 복원
    make clean >/dev/null 2>&1 && make single >/dev/null 2>&1
fi

# ── 13. gitleaks 시크릿 스캔 (staged 대상) ───────────────────
if command -v gitleaks &>/dev/null; then
    GATE=$((GATE+1))
    echo -e "${CYAN}[$GATE] gitleaks 시크릿 스캔${NC}"
    GL_OUT=$(gitleaks protect --staged --redact --no-banner 2>&1)
    GL_EXIT=$?
    if [ "$GL_EXIT" -ne 0 ]; then
        fail "gitleaks: 시크릿 의심 발견"
        echo "$GL_OUT" | tail -20
    else
        pass "gitleaks 통과"
    fi
else
    skip "[$((GATE+1))] gitleaks 미설치 — 권장: https://github.com/gitleaks/gitleaks"
fi

# ── 결과 ─────────────────────────────────────────────────────
echo ""
if [ "$FAILED" -ne 0 ]; then
    echo -e "${RED}═══ 커밋 차단: 품질 게이트 실패 ═══${NC}"
    echo -e "수정 후 다시 커밋하거나, 긴급 시 ${YELLOW}git commit --no-verify${NC}"
    exit 1
fi

echo -e "${GREEN}═══ 품질 게이트 통과 (${GATE}단계) ═══${NC}"
exit 0
