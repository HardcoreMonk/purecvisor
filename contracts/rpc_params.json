{
  "device.nic.list":        { "required": ["vm_id"], "optional": [] },
  "device.nic.attach":      { "required": ["vm_id"], "optional": ["bridge", "model"] },
  "device.nic.detach":      { "required": ["vm_id", "mac"], "optional": [] },
  "vm.eject":               { "required": ["vm_id"], "optional": [] },
  "container.nic.detach":   { "required": ["name", "nic_name"], "optional": [] },
  "container.nic.attach":   { "required": ["name"], "optional": ["bridge", "hwaddr"] },
  "container.snapshot.create": { "required": ["name", "snapshot"], "optional": [] },
  "container.snapshot.delete": { "required": ["name", "snapshot"], "optional": [] },
  "network.mode_set":       { "required": ["name", "mode", "cidr"], "optional": [] },
  "network.dhcp_toggle":    { "required": ["bridge"], "optional": ["enable"] },
  "network.bind_phys":      { "required": ["bridge", "iface"], "optional": [] },
  "network.qos.set":        { "required": [["interface", "vm_name"]], "optional": ["rate_mbps", "burst_kb", "direction"], "keys_via": "alias-fallback" },
  "network.qos.get":        { "required": ["interface"], "optional": [] },
  "network.qos.remove":     { "required": ["interface"], "optional": ["direction"] },
  "ovn.acl.add":            { "required": ["switch", "match"], "optional": ["direction", "priority", "action"] },
  "ovn.acl.list":           { "required": [], "optional": ["switch"] },
  "ovn.dhcp.enable":        { "required": ["subnet", "gateway"], "optional": [] },
  "vm.security_group.set":  { "required": ["vm", "security_group"], "optional": [] },
  "container.set_bandwidth":{ "required": ["name"], "optional": ["nic_name", "inbound_kbps", "outbound_kbps"] },
  "container.set_limits":   { "required": ["name"], "optional": ["cpu_percent", "cpu_weight", "memory_mb"] },
  "storage.pool.health":    { "required": [], "optional": ["pool"] },
  "node.drain":             { "required": [], "optional": ["timeout_sec"] },
  "container.health.set":   { "required": ["name", "type", "target"], "optional": ["interval_sec"] },
  "device.disk.attach":     { "required": ["vm_id", "source", "target"], "optional": ["bus"] }
}
